<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#AA000000"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <!-- Status Info (Floor, HP, etc.) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lost Dungeons"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Floor: 1 | HP: 100/100"
            android:textColor="#DDDDDD"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Menu Button to launch UI Bridge -->
    <Button
        android:id="@+id/btn_widget_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu"
        android:textSize="12sp" />

</LinearLayout>
