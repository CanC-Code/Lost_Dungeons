<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_battle.xml — Full-screen gameplay layout.
    Layer order (back to front):
      1. render_surface   — full-screen OpenGL ES surface (compass drawn natively inside)
      2. touch_overlay    — transparent, captures joystick + swipe-look input in OVERWORLD
      3. btn_ingame_menu  — hamburger icon, top-right corner, always visible in OVERWORLD/MENU
      4. tv_environment_info — path/floor/name HUD, hidden by default, shown when menu opens
      5. layout_menu_buttons — Inventory/Team buttons, bottom-left corner
      6. layout_enemy_status — enemy HP bar, shown during BATTLE
      7. layout_battle_hud   — battle action buttons, shown during BATTLE
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Layer 1: Native OpenGL ES render surface (fills entire screen) -->
    <SurfaceView
        android:id="@+id/render_surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Layer 2: Transparent multi-touch overlay for joystick + camera look -->
    <FrameLayout
        android:id="@+id/touch_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true">

        <!-- Left joystick base (appears dynamically where finger lands) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/joystick_base"
            android:layout_width="120dp"
            android:layout_height="120dp"
            app:cardCornerRadius="60dp"
            app:cardBackgroundColor="#44000000"
            app:cardElevation="0dp"
            android:visibility="invisible" />

        <!-- Left joystick thumb knob -->
        <androidx.cardview.widget.CardView
            android:id="@+id/joystick_thumb"
            android:layout_width="50dp"
            android:layout_height="50dp"
            app:cardCornerRadius="25dp"
            app:cardBackgroundColor="#CCFFFFFF"
            app:cardElevation="2dp"
            android:visibility="invisible" />
    </FrameLayout>

    <!-- Layer 3: In-game menu button (top-right) -->
    <FrameLayout
        android:id="@+id/btn_ingame_menu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="#88000000"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Menu">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="≡"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Layer 4: Environment info HUD (shown when menu is open) -->
    <TextView
        android:id="@+id/tv_environment_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="150dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="56dp"
        android:background="#BB000000"
        android:padding="8dp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:text="Path: Forest | Floor: 1 | Link"
        android:visibility="gone" />

    <!-- Layer 5: Menu Buttons (Inventory & Team) - Bottom-left corner -->
    <LinearLayout
        android:id="@+id/layout_menu_buttons"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="8dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn_inventory"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:text="Inventory"
            android:backgroundTint="#00838F"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btn_team"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="Team"
            android:backgroundTint="#00838F"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Layer 6: Enemy HP status (shown during BATTLE) -->
    <LinearLayout
        android:id="@+id/layout_enemy_status"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal|top"
        android:layout_marginTop="50dp"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_enemy_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF5252"
            android:textStyle="bold"
            android:text="Wild Beast"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:background="#333333">
            <ProgressBar
                android:id="@+id/pb_enemy_hp"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressTint="#FF5252"
                android:progressBackgroundTint="@android:color/transparent"
                android:max="100"
                android:progress="100" />
        </FrameLayout>
    </LinearLayout>

    <!-- Layer 7: Battle action HUD (shown during BATTLE) -->
    <LinearLayout
        android:id="@+id/layout_battle_hud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#1E1E24"
        android:padding="12dp"
        android:visibility="gone">

        <!-- Player HP bar row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_player_hp_text"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:textColor="#00E5FF"
                android:text="Hero HP: "
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:background="#333333">
                <ProgressBar
                    android:id="@+id/pb_player_hp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:progressTint="#00E5FF"
                    android:progressBackgroundTint="@android:color/transparent" />
            </FrameLayout>
        </LinearLayout>

        <!-- Combat log -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_combat_log"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#121212"
            android:layout_marginBottom="12dp" />

        <!-- Primary action row: FIGHT | MAGIC | EVADE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_fight"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="FIGHT"
                android:backgroundTint="#B71C1C"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_magic"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="MAGIC"
                android:backgroundTint="#0D47A1"
                android:layout_marginEnd="4dp" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1">
                <Button
                    android:id="@+id/btn_evade"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="EVADE!"
                    android:backgroundTint="#F57F17"
                    android:textColor="#000000"
                    android:textStyle="bold" />
                <ProgressBar
                    android:id="@+id/pb_evade_timer"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_gravity="bottom"
                    android:progressTint="#FFFFFF"
                    android:progressBackgroundTint="@android:color/transparent"
                    android:visibility="invisible"
                    android:max="100" />
            </FrameLayout>
        </LinearLayout>

        <!-- Secondary action row: ITEM | RUN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btn_item"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="ITEM"
                android:backgroundTint="#1B5E20"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/btn_run"
                android:layout_width="0dp"
                android:layout_height="55dp"
                android:layout_weight="1"
                android:text="RUN"
                android:backgroundTint="#E65100" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>