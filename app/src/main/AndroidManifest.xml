<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name="com.dungeon.DungeonApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light">

        <activity
            android:name="com.dungeon.ui.IntroActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            FIX: BattleActivity now declares Theme.AppCompat.NoActionBar so the
            "Lost Dungeons" title bar is never inflated by the framework at all.
            The supportActionBar?.hide() call in BattleActivity.onCreate() acts as
            a secondary safety net in case the theme is ever changed.
        -->
        <activity
            android:name="com.dungeon.ui.BattleActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar"/>

        <activity
            android:name="com.dungeon.ui.WidgetDialogActivity"
            android:theme="@style/Theme.Transparent.Dialog"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <receiver
            android:name="com.dungeon.widget.DungeonWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/dungeon_widget_info" />
        </receiver>

    </application>
</manifest>
